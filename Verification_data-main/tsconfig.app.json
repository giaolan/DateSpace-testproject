{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue", "public/static/tree.js"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "strict":false,
    "isolatedModules": false,
    "composite": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
